# Google Cloud / Vertex AI configuration
GCP_PROJECT_ID=
GCP_REGION=

# MedGemma Vertex AI Endpoint ID
# After deployment finishes, go to: Vertex AI → Online prediction → Endpoints
# Click "google_medgemma-1_5-4b-it-mg-one-click-deploy" — the numeric ID is in the URL
VERTEX_ENDPOINT_ID=

# Auth: run `gcloud auth application-default login`

# ── Embedding model ───────────────────────────────────────────────────────────
# Options: "huggingface" (default, all-MiniLM-L6-v2) or "medsiglip"
EMBEDDING_MODEL=huggingface

# MedSigLIP via Vertex AI Model Garden (takes priority over EMBEDDING_MODEL when set)
# Deploy from: https://console.cloud.google.com/vertex-ai/publishers/google/model-garden/medsiglip
# Region may differ from GCP_REGION — set it explicitly here.
MEDSIGLIP_ENDPOINT_ID=
MEDSIGLIP_ENDPOINT_REGION=

# EmbeddingGemma via Vertex AI Model Garden (leave blank to use managed text-embedding-005)
# Deploy from: https://console.cloud.google.com/vertex-ai/publishers/google/model-garden/embeddinggemma
EMBEDDINGGEMMA_ENDPOINT_ID=
EMBEDDINGGEMMA_ENDPOINT_REGION=

# HuggingFace token — only needed if using MedSigLIP via HuggingFace (gated model)
# and MEDSIGLIP_ENDPOINT_ID is not set.
HF_TOKEN=
